# LEDSCAR.GARAGE — bloquear mirroring automático (Apache)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP_USER_AGENT} (HTTrack|WebZIP|Teleport|WebCopier|SiteSucker|larbin|libwww|Download\ Demon|GetRight|Go!Zilla|wget|curl|python-requests|scrapy|Bytespider) [NC]
  RewriteRule .* - [F,L]
</IfModule>

<IfModule mod_headers.c>
  Header set X-Robots-Tag "noarchive, noimageindex"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
